# Переменные окружения (скопируй в .env и заполни)

# Сервер
PORT=3001
NODE_ENV=development

# База данных PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# VK Mini App
VK_APP_SECRET="your_vk_app_secret_key"
VK_APP_ID=your_app_id

# CORS — домен фронтенда
CORS_ORIGIN="https://your-app.pages.vk-apps.com"
