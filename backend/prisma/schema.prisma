generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                          Int                                   @id @default(autoincrement())
  name                                        String
  lastName                                    String?                               @map("last_name")
  email                                       String                                @unique
  bio                                         String?
  phone                                       String?
  location                                    String?
  avatar                                      String?
  cover_photo                                 String?
  profile_visibility                          String?                               @default("public")
  show_phone                                  String?                               @default("friends")
  show_email                                  String?                               @default("friends")
  allow_messages                              String?                               @default("everyone")
  show_online                                 String?                               @default("yes")
  verified                                    Boolean?                              @default(false)
  verified_at                                 DateTime?                             @db.Timestamp(6)
  createdAt                                   DateTime?                             @default(now()) @map("created_at") @db.Timestamp(6)
  last_seen                                   DateTime?                             @db.Timestamp(6)
  password_hash                               String                                @db.VarChar(255)
  vk_id                                       Int?                                  @unique
  vk_access_token                             String?
  ok_id                                       String?                               @unique @db.VarChar(255)
  ok_access_token                             String?
  mailru_id                                   String?                               @unique @db.VarChar(255)
  mailru_access_token                         String?
  admin_logs                                  admin_logs[]
  chat_participants                           chat_participants[]
  chats                                       chats[]
  clinic_patients                             clinic_patients[]
  comments                                    comments[]
  error_logs                                  error_logs[]
  favorites                                   favorites[]
  followers_followers_follower_idTousers      followers[]                           @relation("followers_follower_idTousers")
  followers_followers_following_idTousers     followers[]                           @relation("followers_following_idTousers")
  friends_friends_user_id_1Tousers            friends[]                             @relation("friends_user_id_1Tousers")
  friends_friends_user_id_2Tousers            friends[]                             @relation("friends_user_id_2Tousers")
  friendships_friendships_friend_idTousers    friendships[]                         @relation("friendships_friend_idTousers")
  friendships_friendships_user_idTousers      friendships[]                         @relation("friendships_user_idTousers")
  messages                                    messages[]
  notifications_notifications_actor_idTousers notifications[]                       @relation("notifications_actor_idTousers")
  notifications_notifications_user_idTousers  notifications[]                       @relation("notifications_user_idTousers")
  organization_members                        organization_members[]
  organization_vk_notification_admins         organization_vk_notification_admins[]
  organization_vk_settings                    organization_vk_settings[]
  organizations                               organizations[]
  password_history                            password_history[]
  password_resets                             password_resets[]
  pet_change_log                              pet_change_log[]
  pet_registrations                           pet_registrations[]
  pet_treatments                              pet_treatments[]
  pet_vaccinations                            pet_vaccinations[]
  pets                                        Pet[]
  platform_reviews                            platform_reviews[]
  poll_votes                                  poll_votes[]
  reports_reports_moderator_idTousers         reports[]                             @relation("reports_moderator_idTousers")
  reports_reports_reporter_idTousers          reports[]                             @relation("reports_reporter_idTousers")
  user_activity                               user_activity?
  user_activity_log                           user_activity_log[]
  user_activity_logs                          user_activity_logs[]
  user_roles                                  user_roles[]
  user_sessions                               user_sessions[]
  user_stats                                  user_stats[]
  vk_app_user_settings                        vk_app_user_settings?
  vk_radar_pins                               vk_radar_pins[]
  petplatform_ads                             petplatform_ads[]

  @@index([createdAt], map: "idx_users_created_at")
  @@index([email], map: "idx_users_email")
  @@index([name, lastName], map: "idx_users_fullname")
  @@index([last_seen], map: "idx_users_last_seen")
  @@index([name], map: "idx_users_name")
  @@index([vk_id], map: "idx_users_vk_id")
  @@index([vkGroupId], map: "idx_pets_vk_group_id")
  @@map("users")
}

model Pet {
  id                       Int                   @id @default(autoincrement())
  userId                   Int                   @map("user_id")
  name                     String
  species                  String
  breed                    String?
  age                      Int?
  weight                   Decimal?              @db.Decimal(5, 2)
  color                    String?
  gender                   String?
  microchip                String?
  tag_number               String?
  sterilization_date       DateTime?             @db.Date
  createdAt                DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                DateTime?             @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  photo                    String?
  curator_id               Int?
  location                 String?
  relationship             String?               @default("owner") @db.VarChar(20)
  species_id               Int?
  breed_id                 Int?
  birth_date               DateTime?             @db.Date
  age_type                 String?               @default("exact") @db.VarChar(20)
  approximate_years        Int?                  @default(0)
  approximate_months       Int?                  @default(0)
  description              String?
  fur                      String?               @db.VarChar(100)
  ears                     String?               @db.VarChar(100)
  tail                     String?               @db.VarChar(100)
  size                     String?               @db.VarChar(20)
  special_marks            String?
  marking_date             DateTime?             @db.Date
  brand_number             String?               @db.VarChar(50)
  chip_number              String?               @db.VarChar(50)
  location_type            String?               @default("home") @db.VarChar(50)
  location_address         String?
  location_cage            String?               @db.VarChar(100)
  location_contact         String?               @db.VarChar(255)
  location_phone           String?               @db.VarChar(50)
  location_notes           String?
  health_notes             String?
  photoUrl                 String?               @map("photo_url")
  views_count              Int?                  @default(0)
  media_urls               Json?                 @default("[]")
  is_sterilized            Boolean?              @default(false)
  catalog_status           String?               @default("draft") @db.VarChar(50)
  catalog_data             Json?                 @default("{}")
  org_id                   Int?
  vkGroupId                BigInt?               @map("vk_group_id")
  org_pet_number           Int?
  face_photo_url           String?
  body_photo_url           String?
  marking_specialist       String?               @db.VarChar(255)
  marking_org              String?               @db.VarChar(255)
  sterilization_specialist String?               @db.VarChar(255)
  sterilization_org        String?               @db.VarChar(255)
  sterilization_type       String?               @db.VarChar(255)
  city                     String?               @db.VarChar(255)
  clinic_appointments      clinic_appointments[]
  clinic_patients          clinic_patients[]
  favorites                favorites[]
  medical_records          medical_records[]
  org_pet_events           org_pet_events[]
  pet_change_log           pet_change_log[]
  pet_medical_records      pet_medical_records[]
  pet_registrations        pet_registrations[]
  pet_treatments           pet_treatments[]
  pet_vaccinations         pet_vaccinations[]
  users                    User?                 @relation(fields: [curator_id], references: [id], onUpdate: NoAction)
  organizations            organizations?        @relation(fields: [org_id], references: [id], onUpdate: NoAction)
  petplatform_ads          petplatform_ads[]

  @@index([curator_id], map: "idx_pets_curator_id")
  @@index([location_cage], map: "idx_pets_location_cage")
  @@index([location_type], map: "idx_pets_location_type")
  @@index([name], map: "idx_pets_name")
  @@index([org_id], map: "idx_pets_org_id")
  @@index([species], map: "idx_pets_species")
  @@index([userId], map: "idx_pets_user_id")
  @@map("pets")
}

model admin_logs {
  id          Int       @id @default(autoincrement())
  admin_id    Int
  action_type String    @db.VarChar(100)
  target_type String?   @db.VarChar(50)
  target_id   Int?
  target_name String?   @db.VarChar(255)
  details     String?
  ip_address  String?   @db.VarChar(45)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       User      @relation(fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([action_type], map: "idx_admin_logs_action_type")
  @@index([admin_id], map: "idx_admin_logs_admin_id")
  @@index([created_at(sort: Desc)], map: "idx_admin_logs_created_at")
}

model breeds {
  id            Int       @id @default(autoincrement())
  species_id    Int
  name          String
  description   String?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  name_en       String?   @db.VarChar(255)
  origin        String?   @db.VarChar(255)
  size          String?   @db.VarChar(50)
  weight_min    Decimal?  @db.Decimal(5, 2)
  weight_max    Decimal?  @db.Decimal(5, 2)
  temperament   String?
  care_level    String?   @db.VarChar(50)
  image_url     String?
  wikipedia_url String?
  species       species   @relation(fields: [species_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([species_id], map: "idx_breeds_species_id")
}

model chat_participants {
  id                   Int       @id @default(autoincrement())
  chat_id              Int
  user_id              Int
  role                 String?   @default("member") @db.VarChar(50)
  joined_at            DateTime? @default(now()) @db.Timestamp(6)
  last_read_message_id Int?      @default(0)
  hidden_until_msg_id  Int?      @default(0)
  chats                chats     @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([chat_id, user_id])
}

/// This model contains an index with non-default null sort order and requires additional setup for migrations. Visit https://pris.ly/d/default-index-null-ordering for more info.
model chats {
  id                Int                 @id @default(autoincrement())
  last_message_id   Int?
  last_message_at   DateTime?           @db.Timestamp(6)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  type              String?             @default("direct") @db.VarChar(50)
  name              String?             @db.VarChar(255)
  avatar_url        String?             @db.VarChar(1024)
  creator_id        Int?
  invite_token      String?             @unique @db.VarChar(64)
  chat_participants chat_participants[]
  users             User?               @relation(fields: [creator_id], references: [id], onUpdate: NoAction)
  messages          messages[]

  @@index([last_message_at(sort: Desc)], map: "idx_chats_last_message")
}

model clinic_appointments {
  id               Int           @id @default(autoincrement())
  clinic_id        Int
  pet_id           Int
  appointment_date DateTime      @db.Timestamp(6)
  notes            String?
  status           String?       @default("scheduled")
  created_at       DateTime?     @default(now()) @db.Timestamp(6)
  organizations    organizations @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pets             Pet           @relation(fields: [pet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([clinic_id], map: "idx_clinic_appointments_clinic_id")
  @@index([pet_id], map: "idx_clinic_appointments_pet_id")
}

model clinic_patients {
  id              Int           @id @default(autoincrement())
  clinic_id       Int
  pet_id          Int
  owner_id        Int
  medical_history String?
  created_at      DateTime?     @default(now()) @db.Timestamp(6)
  organizations   organizations @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           User          @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pets            Pet           @relation(fields: [pet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([clinic_id], map: "idx_clinic_patients_clinic_id")
  @@index([pet_id], map: "idx_clinic_patients_pet_id")
}

model comments {
  id               Int        @id @default(autoincrement())
  post_id          Int
  user_id          Int
  content          String
  created_at       DateTime?  @default(now()) @db.Timestamp(6)
  updated_at       DateTime?  @default(now()) @db.Timestamp(6)
  parent_id        Int?
  reply_to_user_id Int?
  attachments      Json?      @default("[]")
  status           String?    @default("published") @db.VarChar(20)
  comments         comments?  @relation("commentsTocomments", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_comments   comments[] @relation("commentsTocomments")
  posts            posts      @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            User?      @relation(fields: [reply_to_user_id], references: [id], onUpdate: NoAction)

  @@index([post_id, created_at], map: "idx_comments_post_created")
  @@index([post_id], map: "idx_comments_post_id")
  @@index([user_id], map: "idx_comments_user_id")
}

model email_verification_codes {
  id         Int      @id @default(autoincrement())
  email      String   @db.VarChar(255)
  code       String   @db.VarChar(10)
  expires_at DateTime @db.Timestamp(6)

  @@index([email], map: "idx_email_verification_codes_email")
}

model email_verifications {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token      String    @unique
  expires_at DateTime  @db.Timestamp(6)
  verified   Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model error_logs {
  id            Int       @id @default(autoincrement())
  service       String    @db.VarChar(100)
  endpoint      String    @db.VarChar(255)
  method        String    @db.VarChar(10)
  error_message String
  user_id       Int?
  ip_address    String?   @db.VarChar(45)
  user_agent    String?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  users         User?     @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_error_logs_created_at")
  @@index([service], map: "idx_error_logs_service")
}

model favorites {
  id         Int       @id @default(autoincrement())
  user_id    Int
  post_id    Int?
  pet_id     Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  pets       Pet?      @relation(fields: [pet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  posts      posts?    @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, created_at(sort: Desc)], map: "idx_favorites_user_created")
}

model followers {
  follower_id                         Int
  following_id                        Int
  created_at                          DateTime? @default(now()) @db.Timestamptz(6)
  users_followers_follower_idTousers  User      @relation("followers_follower_idTousers", fields: [follower_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_followers_following_idTousers User      @relation("followers_following_idTousers", fields: [following_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([follower_id, following_id])
  @@index([follower_id], map: "idx_followers_follower_id")
  @@index([following_id], map: "idx_followers_following_id")
}

model friends {
  id                             Int       @id @default(autoincrement())
  user_id_1                      Int
  user_id_2                      Int
  status                         String?   @default("pending")
  created_at                     DateTime? @default(now()) @db.Timestamp(6)
  users_friends_user_id_1Tousers User      @relation("friends_user_id_1Tousers", fields: [user_id_1], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_friends_user_id_2Tousers User      @relation("friends_user_id_2Tousers", fields: [user_id_2], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id_1, user_id_2])
  @@index([user_id_1], map: "idx_friends_user_id_1")
  @@index([user_id_2], map: "idx_friends_user_id_2")
}

model friendships {
  id                                 Int       @id @default(autoincrement())
  user_id                            Int
  friend_id                          Int
  status                             String    @default("pending")
  created_at                         DateTime? @default(now()) @db.Timestamp(6)
  updated_at                         DateTime? @default(now()) @db.Timestamp(6)
  users_friendships_friend_idTousers User      @relation("friendships_friend_idTousers", fields: [friend_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_friendships_user_idTousers   User      @relation("friendships_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, friend_id])
  @@index([friend_id], map: "idx_friendships_friend_id")
  @@index([status], map: "idx_friendships_status")
  @@index([user_id], map: "idx_friendships_user_id")
}

model goose_db_version {
  id         Int      @id @default(autoincrement())
  version_id BigInt
  is_applied Boolean
  tstamp     DateTime @default(now()) @db.Timestamp(6)
}

model likes {
  id            Int       @id @default(autoincrement())
  user_id       Int
  post_id       Int
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  reaction_type String    @default("like") @db.VarChar(20)
  posts         posts     @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, post_id])
  @@index([post_id], map: "idx_likes_post_count")
  @@index([post_id], map: "idx_likes_post_id")
  @@index([user_id], map: "idx_likes_user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model medical_records {
  id            Int           @id @default(autoincrement())
  pet_id        Int
  clinic_id     Int
  record_date   DateTime      @db.Timestamp(6)
  diagnosis     String?
  treatment     String?
  notes         String?
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  record_type   String?       @default("examination") @db.VarChar(50)
  title         String?       @db.VarChar(255)
  medications   String?
  cost          Decimal?      @db.Decimal(10, 2)
  organizations organizations @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pets          Pet           @relation(fields: [pet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([clinic_id], map: "idx_medical_records_clinic_id")
  @@index([record_date(sort: Desc)], map: "idx_medical_records_date")
  @@index([pet_id], map: "idx_medical_records_pet_id")
  @@index([record_type], map: "idx_medical_records_type")
}

model message_attachments {
  id         Int       @id @default(autoincrement())
  message_id Int
  file_path  String
  file_type  String
  file_size  Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  messages   messages  @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([message_id], map: "idx_message_attachments_message_id")
  @@index([message_id, file_type], map: "idx_message_attachments_type")
}

model messages {
  id                  Int                   @id @default(autoincrement())
  chat_id             Int
  sender_id           Int
  content             String
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  pet_id              Int?
  message_attachments message_attachments[]
  chats               chats                 @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               User                  @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([chat_id, created_at], map: "idx_messages_chat_created")
  @@index([chat_id], map: "idx_messages_chat_id")
  @@index([created_at], map: "idx_messages_created_at")
  @@index([sender_id], map: "idx_messages_sender_id")
}

model notifications {
  id                                  Int       @id @default(autoincrement())
  user_id                             Int
  type                                String
  actor_id                            Int
  entity_type                         String?
  entity_id                           Int?
  message                             String
  is_read                             Boolean?  @default(false)
  created_at                          DateTime? @default(now()) @db.Timestamp(6)
  users_notifications_actor_idTousers User      @relation("notifications_actor_idTousers", fields: [actor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_notifications_user_idTousers  User      @relation("notifications_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_notifications_created_at")
  @@index([is_read], map: "idx_notifications_is_read")
  @@index([user_id, created_at(sort: Desc)], map: "idx_notifications_user_created")
  @@index([user_id], map: "idx_notifications_user_id")
  @@index([user_id, is_read], map: "idx_notifications_user_unread")
}

model org_pet_events {
  id          Int       @id @default(autoincrement())
  org_id      Int
  pet_id      Int?
  event_type  String    @db.VarChar(50)
  title       String    @db.VarChar(255)
  description String?
  icon        String?   @default("📌") @db.VarChar(10)
  color       String?   @default("blue") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  metadata    Json?     @default("{}")
  pets        Pet?      @relation(fields: [pet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model organization_members {
  id              Int           @id @default(autoincrement())
  organization_id Int
  user_id         Int
  role            String?       @default("member")
  position        String?
  can_post        Boolean?      @default(false)
  joined_at       DateTime?     @default(now()) @db.Timestamp(6)
  org_avatar      String?
  permissions     Json?         @default("{\"pets\": true, \"finance\": false, \"medical\": true}")
  is_public       Boolean?      @default(true)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           User          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([organization_id, user_id])
  @@index([organization_id], map: "idx_org_members_org_id")
  @@index([user_id], map: "idx_org_members_user_id")
  @@index([user_id, organization_id, role], map: "idx_org_members_user_role")
}

model organization_vk_notification_admins {
  id              Int           @id @default(autoincrement())
  organization_id Int
  user_id         Int
  created_at      DateTime?     @default(now()) @db.Timestamp(6)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           User          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([organization_id, user_id])
  @@index([organization_id], map: "idx_v3_organization_vk_notification_admins_org")
}

model organization_vk_settings {
  id                        Int           @id @default(autoincrement())
  organization_id           Int           @unique
  vk_group_id               BigInt        @unique
  access_token              String
  accept_cross_posts        Boolean       @default(false)
  accepted_tags             Json          @default("[]")
  schedule_interval_minutes Int           @default(60)
  schedule_start_time       String        @default("09:00")
  schedule_end_time         String        @default("21:00")
  duty_admin_user_id        Int?
  city_id                   Int?
  city_name                 String?
  region_name               String?
  lat                       Decimal?      @db.Decimal(10, 8)
  lng                       Decimal?      @db.Decimal(11, 8)
  created_at                DateTime?     @default(now()) @db.Timestamp(6)
  updated_at                DateTime?     @default(now()) @db.Timestamp(6)
  users                     User?         @relation(fields: [duty_admin_user_id], references: [id], onUpdate: NoAction)
