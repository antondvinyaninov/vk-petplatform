  users                User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_v3_vk_app_user_settings_user_id")
}

model vk_post_publications {
  id                Int           @id @default(autoincrement())
  post_id           Int           @unique
  organization_id   Int
  vk_group_id       BigInt
  moderation_status String        @default("pending")
  publish_date      DateTime?     @db.Timestamp(6)
  vk_post_id        BigInt?
  chat_link         String?
  city_id           Int?
  city_name         String?
  region_name       String?
  created_at        DateTime?     @default(now()) @db.Timestamp(6)
  updated_at        DateTime?     @default(now()) @db.Timestamp(6)
  organizations     organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  posts             posts         @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([vk_group_id, moderation_status], map: "idx_v3_vk_post_publications_group_status")
  @@index([organization_id, moderation_status], map: "idx_v3_vk_post_publications_org_status")
}

model vk_radar_pins {
  id              Int            @id @default(autoincrement())
  user_id         Int?
  post_id         Int?           @unique
  organization_id Int?
  type            String
  title           String
  description     String?
  lat             Decimal        @db.Decimal(10, 8)
  lng             Decimal        @db.Decimal(11, 8)
  expires_at      DateTime       @db.Timestamp(6)
  created_at      DateTime?      @default(now()) @db.Timestamp(6)
  updated_at      DateTime?      @default(now()) @db.Timestamp(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onUpdate: NoAction)
  posts           posts?         @relation(fields: [post_id], references: [id], onUpdate: NoAction)
  users           User?          @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([expires_at], map: "idx_v3_vk_radar_pins_expires")
  @@index([user_id], map: "idx_v3_vk_radar_pins_user")
}

model petplatform_ads {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  petId       Int?     @map("pet_id")
  title       String   @db.VarChar(255)
  description String
  type        String   @db.VarChar(50)
  status      String   @default("ACTIVE") @db.VarChar(50)
  lat         Decimal? @db.Decimal(10, 8)
  lng         Decimal? @db.Decimal(11, 8)
  cityTitle   String?  @map("city_title") @db.VarChar(255)
  photoUrl    String?  @map("photo_url")
  vkGroupId   BigInt?  @map("vk_group_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  users       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pets        Pet?     @relation(fields: [petId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([userId], map: "idx_petplatform_ads_user")
  @@index([petId], map: "idx_petplatform_ads_pet")
  @@index([status], map: "idx_petplatform_ads_status")
  @@index([vkGroupId], map: "idx_petplatform_ads_vk_group_id")
  @@map("petplatform_ads")
}
